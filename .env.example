# Path to your Google service account JSON key file
GOOGLE_CREDS_PATH=credentials/service_account.json

# Spreadsheet ID from the URL of your private master Google Sheet:
# https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
SPREADSHEET_ID=your-private-spreadsheet-id-here

# Spreadsheet ID of the separate public-facing Google Sheet
# (shared with participants as view-only)
PUBLIC_SPREADSHEET_ID=your-public-spreadsheet-id-here
